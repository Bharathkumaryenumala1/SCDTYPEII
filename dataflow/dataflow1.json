{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText1",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "sort1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Title as string,",
				"          FirstName as string,",
				"          MiddleName as string,",
				"          LastName as string,",
				"          Gender as string,",
				"          CompanyName as string,",
				"          Email as string,",
				"          PhoneNumber as string,",
				"          DateOfBirth as date,",
				"          AddressLine1 as string,",
				"          City as string,",
				"          State as string,",
				"          Country as string,",
				"          CreatedDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source",
				"source filter(Title=='Mr') ~> filter1",
				"filter1 sort(asc(FirstName, true)) ~> sort1",
				"sort1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerID as string,",
				"          Title as string,",
				"          FirstName as string,",
				"          MiddleName as string,",
				"          LastName as string,",
				"          Gender as string,",
				"          CompanyName as string,",
				"          Email as string,",
				"          PhoneNumber as string,",
				"          DateOfBirth as string,",
				"          AddressLine1 as string,",
				"          City as string,",
				"          State as string,",
				"          Country as string,",
				"          CreatedDate as string",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}